[Unit]
Description=BEC Production Django Backend (Gunicorn)
After=network.target postgresql.service
Requires=postgresql.service

[Service]
User=root
Group=root
WorkingDirectory=/var/www/bec-production/SchoolManagementBackend/CollegeManagement
EnvironmentFile=/var/www/bec-production/SchoolManagementBackend/CollegeManagement/.env
ExecStart=/var/www/bec-production/SchoolManagementBackend/CollegeManagement/venv/bin/gunicorn Swostitech_Acadix.wsgi:application --bind 127.0.0.1:8001 --workers 2 --timeout 60 --access-logfile /var/log/bec-production-access.log --error-logfile /var/log/bec-production-error.log
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
